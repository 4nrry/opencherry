---
---

<div class="relative pt-20 pb-12 flex flex-col items-center text-center px-4 max-w-4xl mx-auto z-10">
  <!-- Glowing logo -->
  <div class="relative group cursor-pointer mb-8">
    <div class="absolute -inset-1.5 bg-gradient-to-r from-cherry to-red-600 rounded-full blur opacity-45 group-hover:opacity-75 transition duration-500"></div>
    <img 
      src="/logo.png" 
      alt="OpenCherry Logo" 
      class="relative h-24 w-24 object-contain rounded-full bg-obsidian-light border border-obsidian-border" 
    />
  </div>

  <!-- Main Headline -->
  <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-white mb-6">
    OpenCherry <span class="text-cherry">🍒</span>
  </h1>
  
  <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed mb-8">
    O painel de controle <span class="text-white font-semibold">multi-repositório × multi-agente</span> definitivo para desenvolvimento assistido por inteligência artificial. Projetado com foco em <span class="text-white font-semibold">GNOME e Ubuntu</span>.
  </p>

  <!-- Tags/Badges -->
  <div class="flex flex-wrap justify-center gap-2 mb-10 text-xs font-mono">
    <span class="px-3 py-1.5 bg-obsidian-card border border-obsidian-border text-zinc-400 rounded-full flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-cherry"></span>
      Ubuntu/GNOME First
    </span>
    <span class="px-3 py-1.5 bg-obsidian-card border border-obsidian-border text-zinc-400 rounded-full flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
      Tauri 2 & SolidJS
    </span>
    <span class="px-3 py-1.5 bg-obsidian-card border border-obsidian-border text-zinc-400 rounded-full flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-cyan-400"></span>
      AGPL-3.0 License
    </span>
  </div>

  <!-- Primary Buttons -->
  <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-md mx-auto">
    <a 
      href="#install" 
      class="w-full sm:w-auto px-8 py-3 bg-cherry text-white rounded-lg font-semibold hover:bg-cherry/90 hover:scale-[1.01] active:scale-[0.99] transition duration-200 border border-cherry/20 text-center shadow-lg shadow-cherry/10"
    >
      Instalar Agora
    </a>
    <a 
      href="https://github.com/4nrry/opencherry" 
      target="_blank"
      rel="noopener noreferrer"
      class="w-full sm:w-auto px-8 py-3 bg-obsidian-card border border-obsidian-border text-zinc-300 rounded-lg font-semibold hover:bg-zinc-800/80 hover:text-white transition duration-200 text-center flex items-center justify-center gap-2"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 1.985 1.087 2.47 1.087.09-.648.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
      </svg>
      Ver no GitHub
    </a>
  </div>
</div>
